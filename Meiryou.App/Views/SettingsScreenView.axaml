<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Meiryou.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:CompileBindings="True"
             x:Class="Meiryou.Views.SettingsScreenView"
             x:DataType="vm:SettingsScreenViewModel">
    
    <StackPanel VerticalAlignment="Center" Spacing="5" MaxWidth="350">
        <TextBlock VerticalAlignment="Center"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Text="SettingsScreenView"
                   TextAlignment="Center"
                   TextWrapping="Wrap"/>
        
        <TextBlock VerticalAlignment="Center"
                   TextAlignment="Center"
                   FontSize="16"
                   Text="{Binding UrlPathSegment}"
                   TextWrapping="Wrap"/>
    </StackPanel>
    
</UserControl>

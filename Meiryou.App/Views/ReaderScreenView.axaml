<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Meiryou.ViewModels"
             xmlns:models="clr-namespace:Meiryou.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:CompileBindings="True"
             x:Class="Meiryou.Views.ReaderScreenView"
             x:DataType="vm:ReaderScreenViewModel">
   
    <StackPanel VerticalAlignment="Center" Spacing="5" MaxWidth="350">
        <TextBlock VerticalAlignment="Center"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Text="ReaderScreenView"
                   TextAlignment="Center"
                   TextWrapping="Wrap"/>
        
        <TextBlock VerticalAlignment="Center"
                   TextAlignment="Center"
                   FontSize="16"
                   Text="{Binding UrlPathSegment}"
                   TextWrapping="Wrap"/>
        
        <Button Content="Add Random Text"
                Command="{Binding AddRandomTextCommand}"
                HorizontalAlignment="Center"
                Padding="15,8"/>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="100">
            <ItemsControl ItemsSource="{Binding Words}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:WordEntry">
                        <TextBlock Text="{Binding Data.Text}" 
                                   Foreground="{Binding ForegroundBrush}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </StackPanel>
    
</UserControl>

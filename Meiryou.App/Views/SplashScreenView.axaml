<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Meiryou.ViewModels"
             mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="800"
             x:Class="Meiryou.Views.SplashScreenView"
             x:DataType="vm:SplashScreenViewModel">
    
    <Design.DataContext>
        <vm:SplashScreenViewModel/>
    </Design.DataContext>
    
    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto" 
          ColumnDefinitions="*,Auto,*"
          Margin="40">
        
        <!-- App Icon -->
        <Image Grid.Row="0" Grid.Column="1" 
               Source="/Assets/avalonia-logo.ico"
               Width="80" Height="80"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Margin="0,0,0,30"/>
        
        <!-- Title -->
        <TextBlock Grid.Row="1" Grid.Column="1"
                   Text="明瞭"
                   FontSize="82"
                   FontWeight="Bold"
                   Foreground="#CDD6F4"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,0,0,20"/>
        
        <!-- Subtitle -->
        <TextBlock Grid.Row="1" Grid.Column="1"
                   Text="Meiryou"
                   FontSize="24"
                   Foreground="#6C7086"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,120,0,0"/>
        
        <!-- Loading Indicator (visible only when loading) -->
        <ProgressBar Grid.Row="3" Grid.Column="1"
                     IsIndeterminate="True"
                     Height="4"
                     Margin="0,20,0,0"
                     VerticalAlignment="Center"
                     IsVisible="{Binding IsLoading}"/>
        
        <!-- Status Message -->
        <TextBlock Grid.Row="4" Grid.Column="1"
                   Text="{Binding StatusMessage}"
                   FontSize="12"
                   Foreground="#6C7086"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,10,0,0"/>
    </Grid>
    
</UserControl>

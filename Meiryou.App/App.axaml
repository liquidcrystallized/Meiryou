<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Meiryou.Converters"
             x:Class="Meiryou.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
             
    <Application.Resources>
        <ResourceDictionary>
            <converters:FamiliarityToGradientBrushConverter x:Key="FamiliarityToGradientBrushConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>